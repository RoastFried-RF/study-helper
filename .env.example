# LMS 계정 (최초 실행 시 CUI에서 입력하면 자동 저장됨)
LMS_USER_ID=
LMS_PASSWORD=

# AI 요약 API 키 (하나 이상 설정)
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Whisper 모델 크기: tiny / base / small / medium / large
# 작을수록 빠르지만 정확도 낮음 (기본값: base)
WHISPER_MODEL=base

# 다운로드 경로 (비워두면 최초 다운로드 시 CUI에서 입력하며 자동 저장됨)
# 기본값: OS 다운로드 폴더 (Windows: C:\Users\사용자명\Downloads, macOS: ~/Downloads)
DOWNLOAD_DIR=

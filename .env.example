# LMS 계정 (최초 실행 시 CUI에서 입력하면 자동 저장됨)
LMS_USER_ID=
LMS_PASSWORD=

# ── 다운로드 설정 (최초 실행 시 설정 화면에서 입력하면 자동 저장됨) ──────────────

# 다운로드 경로 (비워두면 OS 기본 다운로드 폴더 사용)
# Docker: /data/downloads / macOS: ~/Downloads / Windows: C:\Users\사용자명\Downloads
DOWNLOAD_DIR=

# 다운로드 규칙: video(영상만) / audio(음성만) / both(영상+음성)
DOWNLOAD_RULE=

# STT 텍스트 변환 사용 여부: true / false (DOWNLOAD_RULE=video이면 적용 안 됨)
STT_ENABLED=

# Whisper 모델 크기: tiny / base / small / medium / large
# 작을수록 빠르지만 정확도 낮음 (기본값: base)
WHISPER_MODEL=base

# ── AI 요약 설정 ──────────────────────────────────────────────────────────────

# AI 요약 사용 여부: true / false
AI_ENABLED=

# AI 에이전트 종류: gemini / openai
AI_AGENT=

# API 키 (AI_AGENT에 맞는 키만 입력)
GOOGLE_API_KEY=
OPENAI_API_KEY=
